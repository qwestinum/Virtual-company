# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.

# OpenAI (GPT-4o + Whisper)
OPENAI_API_KEY=
# Modèle chat par défaut des agents (vide = gpt-4o-mini). Ex. gpt-4o pour
# une meilleure qualité d'analyse. Redémarrer le serveur dev après changement.
OPENAI_CHAT_MODEL=

# Anthropic (analyse CV via Claude Sonnet 4.6 — comparatif modèle)
# Le CV Analyzer peut router vers OpenAI (défaut) ou Anthropic :
#   CV_ANALYZER_PROVIDER = openai | anthropic   (défaut openai)
# En mode anthropic, ANTHROPIC_API_KEY est requis (console.anthropic.com).
# ANTHROPIC_CHAT_MODEL est optionnel (défaut claude-sonnet-4-6).
# NB : pas de seed côté Anthropic → déterminisme non garanti (seule la
# temperature, défaut 0, est appliquée). Whisper reste sur OpenAI.
CV_ANALYZER_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=

# Embeddings du Vivier (Session V1 — docs/specs/vivier.md §3.4)
# Indexation sémantique des CV du vivier. Routage multi-provider sur le
# même modèle que CV_ANALYZER_PROVIDER :
#   EMBEDDING_PROVIDER = openai   (défaut ; seul implémenté en V1)
#   OPENAI_EMBEDDING_MODEL = text-embedding-3-small (défaut, dimension 1536)
# ⚠️ Changer de provider OU de modèle rend les vecteurs existants NON
# comparables → réindexation complète obligatoire : npm run reindex:vivier.
# La dimension du modèle doit rester alignée avec la colonne vector(1536)
# de scripts/migrate.sql. Réutilise OPENAI_API_KEY ci-dessus.
EMBEDDING_PROVIDER=
OPENAI_EMBEDDING_MODEL=

# Supabase
# Provisionner un projet (free tier OK), puis exécuter scripts/migrate.sql
# dans le SQL editor avant la première utilisation.
# Le vivier requiert l'extension pgvector : l'activer (Dashboard → Database
# → Extensions → « vector ») avant de jouer la migration.
# Si ces variables sont vides, l'app fonctionne en mode volatile (round 1
# Session 5 compatible : aucun crash, persistance désactivée).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Artefacts (Session 5 round 2) : stockés dans le bucket Supabase
# 'artifacts' (créé par scripts/migrate.sql). Pas de variable d'env
# additionnelle — réutilise les credentials Supabase ci-dessus.
# Si Supabase n'est pas configuré, les artefacts restent volatiles
# (mode dégradé Session 4).

# Email (Session 5 round 4 — Mail Composer + Scheduler)
# Resend pour envoi de mails de refus + invitations Cal.com aux
# candidats, et brief d'entretien au DRH. Création de compte 2 min
# sur resend.com. Free tier 100 mails/jour suffisant pour démo.
# Si RESEND_API_KEY est vide, les emails sont skipped (artefact écrit
# avec drive_url = null), l'app continue.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_DRH=

# Cal.com — URL publique de l'event-type pour le booking candidat.
# Format : https://cal.com/<username>/<event-slug>
# Cal.com gère ses propres notifications de réservation côté DRH ;
# notre app envoie en plus un brief préparation au DRH au moment de
# l'invitation.
CAL_COM_EVENT_URL=

# IMAP — chiffrement des credentials des boîtes mail surveillées
# (Session 5 round 5). Master key 32 bytes hex (64 chars). Génère-la
# une seule fois et garde-la précieusement :
#   openssl rand -hex 32
# Sans cette clé, impossible de déchiffrer les passwords stockés
# dans la table mailboxes. Pas de rotation automatique : changer la
# clé invalide toutes les boîtes existantes (il faut les re-saisir).
MAILBOX_ENCRYPTION_KEY=
